Pods/

# Carthage
Carthage/Build/

# fastlane
fastlane/report.xml
fastlane/Preview.html
fastlane/screenshots/**/*.png
fastlane/test_output

# Local dev env (signing identity, team id) — never commit.
# Copy scripts/dev-env.local.sh.example to scripts/dev-env.local.sh
# and fill in your own values.
scripts/dev-env.local.sh

# Development docs (internal plans, specs, design notes)
docs/

# Profiling artifacts
*.profraw

# Git worktrees
.worktrees/

# Sparkle signing keys — the EdDSA private key used to sign update DMGs
# MUST NEVER be committed. scripts/generate-keys.sh writes it here and
# also stores it in the macOS Keychain as a secondary copy.
.sparkle-keys/

# Release build artifacts (signed DMG + appcast.xml) produced by
# scripts/create-release.sh before they get uploaded to a GitHub Release.
releases/
